aws_region          = "us-east-1"
cluster_name        = "techx-tf3"
cluster_version     = "1.30"
namespace           = "techx-tf3"
release_name        = "techx-corp"
nodegroup_name      = "ng-core"
node_instance_type  = "t3.large"
node_desired_size   = 2
node_min_size       = 2
node_max_size       = 3
node_disk_size      = 80
ecr_repository_name = "techx-corp"
image_version       = "1.0"
demo_version        = "1.0"
shipping_image_tag  = "1.0-shipping"
default_image_tag        = "1.0"
bootstrap_from_seed_images = false
seed_image_repository      = "nghiadaulau/techx-corp"
seed_image_tag             = "1.0"

# Dien token that khi muon cho Terraform deploy helm release.
flagd_sync_token    = ""

# false = chi dung cloud nen tang
# true  = dung them namespace + helm release + flagd + shipping hotfix
deploy_release       = false
enable_shipping_hotfix = false

tags = {
  Environment = "phase3"
  Team        = "TF3"
  Project     = "techx-corp"
  ManagedBy   = "terraform"
}
